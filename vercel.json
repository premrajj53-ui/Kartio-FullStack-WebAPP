{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "frontend/build/$1"
    },
    {
      "src": "^/(?!_next/static|_next/image|favicon.ico).*",
      "dest": "frontend/build/index.html"
    }
  ]
}
